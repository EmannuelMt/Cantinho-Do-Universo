{
  "name": "cantinho-backend",
  "version": "1.0.0",
  "description": "Backend para o site Cantinho do Universo",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "setup": "node scripts/setup.js",
    "backup": "node scripts/backup.js",
    "docker:build": "docker build -t cantinho-backend .",
    "docker:run": "docker run -p 5000:5000 cantinho-backend",
    "docker:dev": "docker-compose up",
    "test": "jest --testTimeout=10000",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "eslint": "^9.34.0",
    "express": "^4.21.2",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.5.0",
    "jest": "^30.1.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.8.7",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
